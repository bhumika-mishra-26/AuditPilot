# OpenRouter API Key for Multi-Agent Intelligence
OPENROUTER_API_KEY=your_sk_or_v1_key_here

# Gmail SMTP Configuration for Automated Briefing Dispatch
GMAIL_SENDER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Default Recipient for High-Priority Briefings
BRIEFING_RECIPIENT=recipient@gmail.com

# Neon PostgreSQL Connection String (Cloud Managed)
DATABASE_URL="postgresql://user:password@hostname/dbname?sslmode=require"

# API Mode (Internal Flag)
API_MODE=1
